#!/usr/bin/env python3
from __future__ import annotations

import argparse
import datetime as dt
import pathlib
import re

IGNORE_DIRS = {
    ".git",
    ".next",
    ".venv",
    "venv",
    "node_modules",
    "dist",
    "build",
    "coverage",
}
BAD_NAME_PATTERN = re.compile(r"(?:copy|backup|final-final|final2|v2|tmp)", re.IGNORECASE)
TASK_MARKER_PATTERN = re.compile(r"\b(?:TODO|FIXME)\b")


def iter_files(root: pathlib.Path):
    for path in root.rglob("*"):
        if any(part in IGNORE_DIRS for part in path.parts):
            continue
        if path.is_file():
            yield path


def line_count(path: pathlib.Path) -> int:
    try:
        return sum(1 for _ in path.open("r", encoding="utf-8", errors="ignore"))
    except OSError:
        return 0


def main() -> int:
    parser = argparse.ArgumentParser(description="Report repo cleanup candidates.")
    parser.add_argument("--repo", default=".", help="Repository root")
    parser.add_argument("--max-lines", type=int, default=700)
    parser.add_argument("--stale-doc-days", type=int, default=120)
    parser.add_argument("--write", help="Optional markdown output path")
    args = parser.parse_args()

    root = pathlib.Path(args.repo).resolve()
    docs_root = root / "docs" / "agent"
    findings: list[str] = []

    if docs_root.exists():
        index_text = (docs_root / "index.md").read_text(encoding="utf-8") if (docs_root / "index.md").exists() else ""
        for doc in docs_root.glob("*.md"):
            text = doc.read_text(encoding="utf-8")
            if f"docs/agent/{doc.name}" not in index_text and doc.name != "index.md":
                findings.append(f"- Unlinked agent doc: `docs/agent/{doc.name}`")
            match = re.search(r"^last_reviewed:\s*(.+)$", text, re.MULTILINE)
            if match:
                try:
                    age = (dt.date.today() - dt.date.fromisoformat(match.group(1).strip())).days
                    if age > args.stale_doc_days:
                        findings.append(f"- Stale doc: `docs/agent/{doc.name}` ({age} days)")
                except ValueError:
                    findings.append(f"- Invalid last_reviewed date: `docs/agent/{doc.name}`")
            else:
                findings.append(f"- Missing last_reviewed metadata: `docs/agent/{doc.name}`")

    task_marker_hits: list[str] = []
    oversized: list[str] = []
    suspicious_names: list[str] = []
    for path in iter_files(root):
        rel = path.relative_to(root)
        if BAD_NAME_PATTERN.search(path.name):
            suspicious_names.append(f"- Suspicious filename: `{rel}`")
        lines = line_count(path)
        if lines > args.max_lines:
            oversized.append(f"- Oversized file: `{rel}` ({lines} lines)")
        try:
            text = path.read_text(encoding="utf-8", errors="ignore")
        except OSError:
            continue
        count = len(TASK_MARKER_PATTERN.findall(text))
        if count >= 3:
            task_marker_hits.append(f"- Task-marker hotspot: `{rel}` ({count} hits)")

    sections = [
        "# Agent GC Report",
        "",
        f"Generated on {dt.date.today().isoformat()}.",
        "",
        "## Findings",
    ]
    body = findings + oversized + suspicious_names + task_marker_hits
    if not body:
        body = ["- No cleanup candidates found with the current thresholds."]
    report = "\n".join(sections + body) + "\n"
    print(report)
    if args.write:
        output_path = pathlib.Path(args.write)
        output_path.write_text(report, encoding="utf-8")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
